---
const links = [
  { name: "X", url: "https://x.com/mager" },
  { name: "GitHub", url: "https://github.com/mager" },
  { name: "Spotify", url: "https://open.spotify.com/user/magerleagues" },
  { name: "LinkedIn", url: "https://linkedin.com/in/magerleagues" },
];
---

<footer>
  {
    links.map((link, index) => (
      <>
        <a href={link.url}>{link.name}</a>
        {index < links.length - 1 && " / "}
      </>
    ))
  }
</footer>
